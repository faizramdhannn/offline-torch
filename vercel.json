{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://offline-tracking.vercel.app/"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://offline-tracking.vercel.app/"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/refresh-stock",
      "schedule": "*/5 * * * *"
    }
  ]
}